APP_NAME=Карточка
APP_ENV=development

# ОБЯЗАТЕЛЬНО поменять в production!
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-random-64-char-string-in-production

ACCESS_TOKEN_EXPIRE_MINUTES=1440
BASE_URL=http://localhost:8000

DATABASE_URL=postgresql+asyncpg://kartochka:kartochka_dev_password@localhost:5432/kartochka
TEST_DATABASE_URL=sqlite+aiosqlite:///./test.db

STORAGE_PATH=./storage
FONTS_PATH=./fonts

FREE_PLAN_MAX_TEMPLATES=3
FREE_PLAN_MAX_GENERATIONS_PER_DAY=10
MAX_BATCH_SIZE=500
BATCH_CHUNK_SIZE=10

# Redis (Celery broker) — обязателен для пакетной генерации
REDIS_URL=redis://localhost:6379/0

# Шифрование API-ключей маркетплейсов — ОБЯЗАТЕЛЬНО в production!
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# YooKassa — оставить пустым если биллинг не нужен
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
PRO_PLAN_PRICE_RUB=1490

# Telegram-уведомления — оставить пустым если не нужно
TELEGRAM_BOT_TOKEN=

# Публикация в маркетплейсы
PUBLISH_CHUNK_SIZE=20
PUBLISH_CHUNK_DELAY=3
